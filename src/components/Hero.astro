---
import { Image } from 'astro:assets';
import path from '../assets/path.jpg';
---
<section
  id="top"
  class="relative flex flex-col md:flex-row items-center
         min-h-[82vh] gap-14 md:gap-12 lg:gap-20
         px-6 md:px-12 lg:px-20 pt-14 md:pt-16 pb-20 md:pb-24"
>
  <!-- Left column: text -->
  <div class="relative z-10 w-full md:w-1/2 space-y-8">
    <p class="text-[12px] md:text-[13px] tracking-[0.22em] uppercase text-ink-muted">
      <span class="inline-block w-7 h-px bg-accent align-middle mr-3"></span>
      Jeugdzorg
    </p>

    <h1 class="font-serif font-normal leading-[1.05] tracking-[-0.01em]
               text-[44px] md:text-[60px] lg:text-[76px]
               max-w-[14ch]">
      Jeugdzorg met
      <span class="italic text-accent">hart en toewijding.</span>
    </h1>

    <p class="text-ink-muted text-[17px] md:text-[18px] leading-[1.6] max-w-md">
      Al jarenlang werk ik met toewijding in de jeugdzorg. Dit is het vak dat ik
      ken &mdash; waar mijn hart ligt, en waar ik mij dagelijks voor inzet.
    </p>
  </div>

  <!-- Right column: image with floating pull-quote card -->
  <div class="relative w-full md:w-1/2 max-w-xl mx-auto md:max-w-none">
    <Image
      src={path}
      alt=""
      widths={[640, 960, 1280]}
      sizes="(min-width: 1024px) 640px, (min-width: 768px) 50vw, 100vw"
      format="avif"
      quality={55}
      loading="eager"
      fetchpriority="high"
      class="w-full aspect-[4/5] md:aspect-[3/4] object-cover rounded-3xl shadow-xl"
    />

    <figure
      class="absolute -bottom-10 left-4 right-4
             md:-left-10 md:right-auto md:-bottom-12 md:max-w-[19rem]
             bg-bg/95 backdrop-blur-sm
             border border-rule rounded-2xl shadow-lg
             p-6 md:p-7"
    >
      <span aria-hidden="true"
            class="font-serif italic text-accent text-3xl leading-none align-top mr-1">&ldquo;</span>
      <blockquote
        class="font-serif italic text-[19px] md:text-[20px] leading-[1.35] text-ink inline"
      >
        Écht verschil maken voor jongeren en gezinnen.
      </blockquote>
    </figure>
  </div>
</section>
