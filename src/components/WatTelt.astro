<section
  id="wat-telt"
  class="px-6 md:px-12 lg:px-20 py-14 md:py-20 border-t border-rule"
>
  <div class="max-w-3xl mx-auto text-center space-y-8">
    <p class="text-[11px] tracking-[0.18em] uppercase text-ink-muted">Wat telt</p>

    <p
      class="font-serif text-[26px] md:text-[34px] leading-[1.3] tracking-[-0.005em]
             text-ink max-w-[28ch] mx-auto"
    >
      Vertrouwen ontstaat in de <span class="italic text-accent">tijd</span>,
      niet in één gesprek.
    </p>

    <p class="text-[17px] md:text-[18px] leading-[1.7] text-ink-muted max-w-prose mx-auto">
      Daarom werk ik graag in trajecten waar continuïteit en kleine stappen
      het echte werk doen &mdash; voor jongeren, voor gezinnen, en voor de
      mensen om hen heen.
    </p>
  </div>
</section>
