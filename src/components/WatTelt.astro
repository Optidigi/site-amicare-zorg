---
import { Image } from 'astro:assets';
import journal from '../assets/journal.jpg';
---
<section
  id="wat-telt"
  class="relative flex flex-col md:flex-row-reverse items-center
         gap-12 md:gap-12 lg:gap-20
         px-6 md:px-12 lg:px-20 py-14 md:py-20 border-t border-rule"
>
  <!-- Left column: text -->
  <div class="w-full md:w-1/2 space-y-6 md:space-y-8">
    <p class="text-[11px] tracking-[0.18em] uppercase text-ink-muted">Wat telt</p>

    <p
      class="font-serif text-[28px] md:text-[36px] lg:text-[44px]
             leading-[1.2] tracking-[-0.005em] text-ink max-w-[20ch]"
    >
      Vertrouwen ontstaat in de <span class="italic text-accent">tijd</span>,
      niet in één gesprek.
    </p>

    <p class="text-[17px] md:text-[18px] leading-[1.7] text-ink-muted max-w-prose">
      Daarom werk ik graag in trajecten waar continuïteit en kleine stappen
      het echte werk doen &mdash; voor jongeren, voor gezinnen, en voor de
      mensen om hen heen.
    </p>
  </div>

  <!-- Right column: image -->
  <div class="w-full md:w-1/2 max-w-xl mx-auto md:max-w-none">
    <Image
      src={journal}
      alt=""
      widths={[640, 960, 1280]}
      sizes="(min-width: 768px) 50vw, 100vw"
      format="avif"
      quality={70}
      loading="lazy"
      class="w-full aspect-[4/5] md:aspect-[4/3] object-cover rounded-3xl shadow-md"
    />
  </div>
</section>
