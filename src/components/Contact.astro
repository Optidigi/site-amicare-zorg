  class="px-6 md:px-12 lg:px-20 py-24 md:py-32 border-t border-rule"
>
  <div class="max-w-3xl mx-auto text-center space-y-8">
    <p class="text-[11px] tracking-[0.18em] uppercase text-ink-muted">Contact</p>

    <h2 class="font-serif text-[28px] md:text-[34px] leading-[1.25] tracking-[-0.005em] text-ink-muted max-w-[24ch] mx-auto">
      Wilt u meer informatie of in contact komen?
    </h2>

    <a
      href="mailto:info@amicare-zorg.nl"
      class="inline-block font-serif text-[28px] md:text-[40px]
             text-ink underline decoration-1 underline-offset-[8px]
